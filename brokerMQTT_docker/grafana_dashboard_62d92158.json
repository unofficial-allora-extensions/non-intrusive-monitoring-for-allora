      "targets": [
        {
          "datasource": {
            "type": "influxdb",
            "uid": "${DS_INFLUXDB}"
          },
          "query": "import \"internal/debug\"\r\n\r\nbase =\r\n    from(bucket: \"allora-bucket\")\r\n        |> range(start: -15m)\r\n        |> filter(fn: (r) => r.mqtt_topic == \"allora/gateway_01/62d92158/metrics\")\r\n        |> filter(fn: (r) => r._field == \"Temperature\")\r\n        |> aggregateWindow(every: 10s, fn: mean, createEmpty: false)\r\nline =\r\n    base\r\n        |> map(fn: (r) => ({\r\n            r with\r\n            _field: \"BASE\",\r\n        }))\r\n\r\nok =\r\n    base\r\n        |> map(fn: (r) => ({\r\n            r with\r\n            _field: \"OK\",\r\n            _value: if r._value < 40.0 then r._value else debug.null(type: \"float\"),\r\n        }))\r\n\r\nwarn =\r\n    base\r\n        |> map(fn: (r) => ({\r\n            r with\r\n            _field: \"WARN\",\r\n            _value: if r._value >= 40.0 and r._value < 60.0 then r._value else debug.null(type: \"float\"),\r\n        }))\r\n\r\nalarm =\r\n    base\r\n        |> map(fn: (r) => ({\r\n            r with\r\n            _field: \"ALARM\",\r\n            _value: if r._value >= 60.0 then r._value else debug.null(type: \"float\"),\r\n        }))\r\n\r\nunion(tables: [line, ok, warn, alarm])\r\n    |> yield(name: \"Temperature_bands\")",
          "refId": "A"
        }
      ],
      "title": "Internal Temperature (°C)",
      "type": "timeseries"
